{% extends "global_layout.jinja2" %}

{% block title %}Alleles Recently Added to SGD{% endblock %}

{% block head %}
<script>
  var recent_allele_data = {{ alleles_js|safe }};
  var recent_allele_dates = { start: "{{ start }}", end: "{{ end }}" };
</script>
{% endblock %}

{% block body %}

<div class="row">

    {% include "navbar.jinja2" %}

    <div class="small-12 medium-10 columns content-column">

        <script>
            add_navbar_title("Alleles Recently Added to SGD");
            add_navbar_element('Alleles', 'alleles');
        </script>

        <section id="alleles" data-magellan-destination="alleles">
            <h1>Alleles Recently Added to SGD</h1>
            <h2 class="subheader" id="recent_allele_dates"></h2>
            <span id="recent_allele_table_header" class="round secondary label"></span>
            <hr />
            <div>
                {% set table_id = "recent_allele_table" %}
                {% include "allele_table.jinja2" %}
            </div>
        </section>
    </div>
</div>
{% endblock body %}

{% block scripts %}
<script src="{{asset_root}}/js/recent_alleles.js"></script>
{% endblock scripts %}
