{% extends "global_layout.jinja2" %}

{% block title %}GO Annotations Recently Added to SGD{% endblock %}

{% block head %}
<script>
  var recent_go_data = {{ go_annotations_js|safe }};
  var recent_go_dates = { start: "{{ start }}", end: "{{ end }}" };
</script>
{% endblock %}

{% block body %}

<div class="row">

    {% include "navbar.jinja2" %}

    <div class="small-12 medium-10 columns content-column">

        <script>
            add_navbar_title("GO Annotations Recently Added to SGD");
            add_navbar_element('Annotations', 'annotations');
        </script>

        <section id="annotations" data-magellan-destination="annotations">
            <h1>GO Annotations Recently Added to SGD</h1>
            <h2 class="subheader" id="recent_go_dates"></h2>
            <span id="recent_go_table_header" class="round secondary label"></span>
            <hr />
            {# Top summary temporarily disabled
            <div id="recent_go_summary" class="chem2-summary"></div>
            #}
            <div>
                {% set table_id = "recent_go_table" %}
                {% include "go_table.jinja2" %}
            </div>
        </section>
    </div>
</div>
{% endblock body %}

{% block scripts %}
<script src="{{asset_root}}/js/evidence.js"></script>
<script src="{{asset_root}}/js/recent_go.js"></script>
{% endblock scripts %}
